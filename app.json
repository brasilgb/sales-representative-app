{
  "expo": {
    "name": "Vetor Pet",
    "slug": "vetorpet",
    "version": "1.0.3",
    "description": "Vendas em campo para distribuidores e representantes de suprimentos para pet shops e clínicas veterinárias.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "backgroundColor": "#0B78BC",
    "scheme": "vetorpet",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B78BC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.andersonbrodrigues.vetorpet"
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B78BC"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.andersonbrodrigues.vetorpet",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita que o VetorPet acesse suas fotos para anexar o comprovante da despesa.",
          "cameraPermission": "Permita que o VetorPet use a câmera para fotografar o comprovante da despesa."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permita que o VetorPet use o Face ID para entrar na sua conta."
        }
      ],
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ffc8b312-61f1-4b47-8e09-2aaca24c5ad5"
      }
    },
    "owner": "andersonbrodrigues"
  }
}
